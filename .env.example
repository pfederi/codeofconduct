# MongoDB connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pumpfoiling?retryWrites=true&w=majority

# MongoDB database name (can be omitted if specified in the URI)
MONGODB_DB=pumpfoiling 